{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend"
        },
        "ai-service": {
            "root": "ai-service"
        }
    },
    "rewrites": [
        {
            "source": "/api/ai(/.*)?",
            "destination": {
                "type": "service",
                "service": "ai-service"
            }
        },
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
